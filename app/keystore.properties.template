# 签名配置模板
#
# 使用方法：
# 1. 复制此文件为 keystore.properties
# 2. 填写实际的密码信息
# 3. 不要提交到 Git

# Keystore 文件名（相对于 app 目录）
RELEASE_KEYSTORE_FILE=release-keystore.jks

# Keystore 密码
RELEASE_KEYSTORE_PASSWORD=your_keystore_password_here

# Key 别名
RELEASE_KEY_ALIAS=release

# Key 密码
RELEASE_KEY_PASSWORD=your_key_password_here
