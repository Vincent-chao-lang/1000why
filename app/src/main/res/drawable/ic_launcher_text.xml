<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 背景：渐变圆形 -->
    <item>
        <shape android:shape="oval">
            <gradient
                android:startColor="#667eea"
                android:endColor="#764ba2"
                android:angle="45"/>
            <size android:width="108dp" android:height="108dp"/>
        </shape>
    </item>
    <!-- 内圈 -->
    <item android:top="8dp" android:bottom="8dp" android:left="8dp" android:right="8dp">
        <shape android:shape="oval">
            <solid android:color="#1a1a2e"/>
            <stroke android:width="2dp" android:color="#FFFFFF"/>
        </shape>
    </item>
    <!-- 中间的圆点 -->
    <item android:top="30dp" android:bottom="30dp" android:left="30dp" android:right="30dp">
        <shape android:shape="oval">
            <solid android:color="#FFFFFF"/>
        </shape>
    </item>
</layer-list>
